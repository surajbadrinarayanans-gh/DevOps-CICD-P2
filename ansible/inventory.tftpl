[bastion]
bastion ansible_host=${bastion_ip} ansible_user=ubuntu ansible_ssh_private_key_file=../terraform/txn-key.pem

[app]
app ansible_host=${app_ip} ansible_user=ubuntu ansible_ssh_private_key_file=../terraform/txn-key.pem

[all:vars]
ansible_ssh_common_args='-o ProxyCommand="ssh -W %h:%p -i ../terraform/txn-key.pem ubuntu@${bastion_ip}"'